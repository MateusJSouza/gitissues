# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Connection string with connection pooling (used by Prisma at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/gitissues?sslmode=require&pgbouncer=true"

# Direct connection string (used by Prisma Migrate — bypasses PgBouncer)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/gitissues?sslmode=require"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-nextauth-secret-here"

# URL da aplicação (sem trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Crie em: https://github.com/settings/developers → OAuth Apps
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID="your-github-oauth-app-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-client-secret"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="GitIssues"
